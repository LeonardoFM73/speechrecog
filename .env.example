# ──────────────────────────────────────────────
# Server: backend + VOICEVOX run on remote host (10.100.101.12).
# Frontend runs locally in Docker, talks to backend over LAN.
# Mic access = browser → local frontend → remote backend.
# ──────────────────────────────────────────────

# Host port for the backend container (server-side).
# Maps to container port 8000 inside the backend.
BACKEND_PORT=8001

# Frontend: port exposed on the local machine (where the browser runs).
FRONTEND_PORT=3000

# Backend API URL — reachable from the BROWSER (running locally).
# Baked into the frontend at build time by Next.js.
NEXT_PUBLIC_API_URL=http://10.100.101.12:8001

# ──────────────────────────────────────────────
# LLM (OpenAI-compatible chat-completions endpoint, e.g. vLLM)
# Runs on server (or another LAN host). Required for /chat endpoint.
# ──────────────────────────────────────────────
OPENAI_BASE_URL=http://10.100.101.12:5091/v1
OPENAI_API_KEY=EMPTY
OPENAI_MODEL=qwen35-9b

# ──────────────────────────────────────────────
# VOICEVOX Engine — runs on the same SERVER as the backend.
# Backend reaches VOICEVOX via localhost (or 127.0.0.1) inside the server.
# ──────────────────────────────────────────────
# Inside the backend container/server, VOICEVOX is at localhost:50021.
VOICEVOX_URL=http://localhost:50021
# Default speaker style_id (used when the UI doesn't pick one).
# 1=四国めたん ノーマル, 2=四国めたん あまあま, 3=ずんだもん ノーマル, ...
VOICEVOX_DEFAULT_SPEAKER=2

# Host port for the VOICEVOX Engine container (only used in Docker compose).
VOICEVOX_PORT=50021