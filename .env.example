# ──────────────────────────────────────────────
# docker-compose environment variables
# ──────────────────────────────────────────────

# Frontend: port exposed to the host
FRONTEND_PORT=3000

# Backend API URL for the frontend container
# Use Docker internal DNS when both are in the same compose network
NEXT_PUBLIC_API_URL=http://backend:8000

# ──────────────────────────────────────────────
# LLM (Google Gemini) — required for /chat endpoint
# Get a key at https://aistudio.google.com/apikey
# Leave blank to disable the roleplay chat feature
# ──────────────────────────────────────────────
GEMINI_API_KEY=

# ──────────────────────────────────────────────
# Local TTS (VOICEVOX Engine) — required for audio replies in roleplay mode
# The backend calls VOICEVOX at this URL to convert reply_jp → audio/wav.
# ──────────────────────────────────────────────
# When running Docker compose, use the service name "voicevox".
# When running backend on host (dev), use http://localhost:50021.
VOICEVOX_URL=http://localhost:50021
# Default speaker style_id (used when the UI doesn't pick one).
# 1=四国めたん ノーマル, 2=四国めたん あまあま, 3=ずんだもん ノーマル, ...
# See GET /speakers for the full list — user can override per-turn in the UI.
VOICEVOX_DEFAULT_SPEAKER=2

# Host port for the VOICEVOX Engine container (only used in Docker compose).
VOICEVOX_PORT=50021

# ──────────────────────────────────────────────
# Local development overrides (uncomment to use)
# ──────────────────────────────────────────────
# FRONTEND_PORT=3000
# NEXT_PUBLIC_API_URL=http://localhost:8000
